"""
DecodeLabs - Project 1: Password Strength Checker
---------------------------------------------------
Evaluates a password and classifies it as Weak, Medium, or Strong
based on length, character variety, and common/leaked password checks.

Key Requirements covered:
- Check password length
- Check use of numbers, symbols, and uppercase letters
- Display password strength result
- Bonus: leaked/common password check
- Bonus: character variety requirement
"""

import string

# ----------------------------------------------------------------------
# A small sample list of extremely common / leaked passwords.
# In a real-world tool, this would be a much larger dataset
# (e.g. the "RockYou" leaked password list or HaveIBeenPwned's API).
# ----------------------------------------------------------------------
COMMON_PASSWORDS = {
    "123456", "123456789", "qwerty", "password", "12345678",
    "111111", "123123", "abc123", "password1", "iloveyou",
    "admin", "letmein", "welcome", "monkey", "dragon",
    "qwerty123", "1q2w3e4r", "000000", "1234", "12345",
}


def check_length(password: str) -> int:
    """Return points based on password length."""
    length = len(password)
    if length >= 12:
        return 2
    elif length >= 8:
        return 1
    return 0


def check_character_variety(password: str) -> dict:
    """Check which character types are present in the password."""
    return {
        "lowercase": any(c in string.ascii_lowercase for c in password),
        "uppercase": any(c in string.ascii_uppercase for c in password),
        "digit": any(c in string.digits for c in password),
        "symbol": any(c in string.punctuation for c in password),
    }


def is_common_password(password: str) -> bool:
    """Check if the password appears in the common/leaked password list."""
    return password.lower() in COMMON_PASSWORDS


def calculate_strength(password: str):
    """
    Calculate password strength.
    Returns a tuple: (strength_label, score, details_dict)
    """
    details = {}

    # 1. Leaked/common password check (automatic fail -> Weak)
    if is_common_password(password):
        details["common_password"] = True
        return "Weak", 0, details
    details["common_password"] = False

    score = 0

    # 2. Length check
    length_points = check_length(password)
    score += length_points
    details["length"] = len(password)
    details["length_points"] = length_points

    # 3. Character variety check
    variety = check_character_variety(password)
    variety_points = sum(variety.values())
    score += variety_points
    details["variety"] = variety
    details["variety_points"] = variety_points

    # 4. Minimum variety requirement (bonus rule):
    # Even with great length, require at least 3 character types
    # for anything above "Weak".
    types_present = variety_points

    # 5. Map score -> strength label
    if types_present < 2 or score <= 2:
        strength = "Weak"
    elif types_present >= 3 and score >= 5:
        strength = "Strong"
    else:
        strength = "Medium"

    details["score"] = score
    return strength, score, details


def print_report(password: str):
    strength, score, details = calculate_strength(password)

    print("\n" + "=" * 40)
    print(f"Password entered : {'*' * len(password)}")
    print(f"Strength Result  : {strength}")
    print("-" * 40)

    if details.get("common_password"):
        print("⚠ This password is in the common/leaked password list.")
        print("  -> Automatically marked as Weak, regardless of complexity.")
    else:
        print(f"Length           : {details['length']} characters "
              f"(+{details['length_points']} pts)")
        variety = details["variety"]
        print(f"Lowercase letter : {'Yes' if variety['lowercase'] else 'No'}")
        print(f"Uppercase letter : {'Yes' if variety['uppercase'] else 'No'}")
        print(f"Digit            : {'Yes' if variety['digit'] else 'No'}")
        print(f"Symbol           : {'Yes' if variety['symbol'] else 'No'}")
        print(f"Total Score      : {details['score']} / 6")

    print("=" * 40)

    # Friendly improvement tips
    if strength != "Strong":
        print("\nTips to improve your password:")
        if details.get("common_password"):
            print(" - Avoid common/predictable passwords entirely.")
        else:
            if details["length"] < 12:
                print(" - Use at least 12 characters.")
            variety = details["variety"]
            if not variety["uppercase"]:
                print(" - Add an uppercase letter.")
            if not variety["lowercase"]:
                print(" - Add a lowercase letter.")
            if not variety["digit"]:
                print(" - Add a number.")
            if not variety["symbol"]:
                print(" - Add a symbol (e.g. !, @, #, $).")


def main():
    print("DecodeLabs - Password Strength Checker")
    print("Type 'exit' to quit.\n")

    while True:
        password = input("Enter a password to check: ").strip()
        if password.lower() == "exit":
            print("Goodbye!")
            break
        if not password:
            print("Please enter a non-empty password.\n")
            continue
        print_report(password)
        print()


if __name__ == "__main__":
    main()
