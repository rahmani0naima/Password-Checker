<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Password Security Assessment</title>
<style>
  :root{
    --paper:#0E1116;
    --surface:#161A22;
    --ink:#E7E9EE;
    --ink-soft:#8A93A3;
    --line:#2A2F3A;
    --vault:#5B8DBF;
    --vault-soft:#1D2A38;
    --danger:#FF6E62;
    --danger-soft:#2E1917;
    --warning:#E8B44E;
    --warning-soft:#2E2515;
    --success:#4FCB90;
    --success-soft:#132A20;
    --mono-bg:#080A0E;
    --mono-text:#C9E8D8;
    font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
  }

  *{box-sizing:border-box;}

  body{
    margin:0;
    background:var(--paper);
    color:var(--ink);
    padding:40px 20px;
    display:flex;
    justify-content:center;
  }

  .sheet{
    width:100%;
    max-width:640px;
    background:var(--surface);
    border:1px solid var(--line);
    border-radius:2px;
    box-shadow:0 8px 30px rgba(0,0,0,0.45);
  }

  .letterhead{
    padding:28px 32px 20px;
    border-bottom:1px solid var(--line);
    display:flex;
    justify-content:space-between;
    align-items:flex-start;
  }

  .letterhead h1{
    font-family:Georgia,"Iowan Old Style","Palatino Linotype",serif;
    font-size:22px;
    font-weight:600;
    letter-spacing:0.01em;
    margin:0 0 4px;
    color:var(--ink);
  }

  .letterhead .sub{
    font-size:12.5px;
    color:var(--ink-soft);
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  }

  .doc-id{
    text-align:right;
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    font-size:11px;
    color:var(--ink-soft);
    line-height:1.6;
    white-space:nowrap;
  }

  .body{
    padding:28px 32px 32px;
  }

  .field-label{
    font-size:11px;
    text-transform:uppercase;
    letter-spacing:0.08em;
    color:var(--ink-soft);
    margin-bottom:8px;
    font-weight:600;
  }

  .input-row{
    display:flex;
    background:var(--mono-bg);
    border-radius:4px;
    overflow:hidden;
    margin-bottom:26px;
  }

  .input-row input{
    flex:1;
    background:transparent;
    border:none;
    outline:none;
    color:var(--mono-text);
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    font-size:15px;
    padding:14px 16px;
    letter-spacing:0.02em;
  }

  .input-row input::placeholder{ color:#5c6a75; }

  .eye-btn{
    background:none;
    border:none;
    color:#8fa3ad;
    cursor:pointer;
    padding:0 16px;
    font-family: ui-monospace, monospace;
    font-size:11px;
    letter-spacing:0.05em;
  }
  .eye-btn:hover{ color:#D8E4E8; }

  /* Verdict stamp */
  .verdict-wrap{
    display:flex;
    align-items:center;
    justify-content:space-between;
    margin-bottom:22px;
    gap:16px;
  }

  .meter{
    flex:1;
  }

  .meter-track{
    height:8px;
    background:var(--vault-soft);
    border-radius:4px;
    overflow:hidden;
    margin-bottom:6px;
  }

  .meter-fill{
    height:100%;
    width:0%;
    background:var(--line);
    transition:width 0.35s ease, background 0.35s ease;
  }

  .meter-scale{
    display:flex;
    justify-content:space-between;
    font-size:10px;
    color:var(--ink-soft);
    font-family: ui-monospace, monospace;
    text-transform:uppercase;
    letter-spacing:0.06em;
  }

  .stamp{
    flex-shrink:0;
    border:2px solid var(--line);
    color:var(--ink-soft);
    font-family: Georgia, serif;
    font-weight:700;
    font-size:13px;
    letter-spacing:0.08em;
    padding:8px 14px;
    border-radius:3px;
    transform:rotate(-3deg);
    text-transform:uppercase;
    white-space:nowrap;
    transition:all 0.25s ease;
  }
  .stamp.weak{ color:var(--danger); border-color:var(--danger); background:var(--danger-soft); }
  .stamp.medium{ color:var(--warning); border-color:var(--warning); background:var(--warning-soft); }
  .stamp.strong{ color:var(--success); border-color:var(--success); background:var(--success-soft); }

  /* Data table */
  .data-table{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:1px;
    background:var(--line);
    border:1px solid var(--line);
    margin-bottom:22px;
    border-radius:2px;
    overflow:hidden;
  }

  .data-cell{
    background:var(--surface);
    padding:12px 16px;
  }

  .data-cell .k{
    font-size:10.5px;
    text-transform:uppercase;
    letter-spacing:0.07em;
    color:var(--ink-soft);
    margin-bottom:4px;
  }

  .data-cell .v{
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    font-size:16px;
    font-weight:600;
  }
  .v.danger{ color:var(--danger); }
  .v.success{ color:var(--success); }
  .v.warning{ color:var(--warning); }

  /* Character type chips */
  .chips{
    display:flex;
    gap:8px;
    margin-bottom:22px;
    flex-wrap:wrap;
  }

  .chip{
    font-family: ui-monospace, monospace;
    font-size:11.5px;
    padding:6px 10px;
    border-radius:3px;
    border:1px solid var(--line);
    color:var(--ink-soft);
    background:var(--paper);
  }
  .chip.on{
    border-color:var(--success);
    color:var(--success);
    background:var(--success-soft);
  }

  /* Findings */
  .findings{
    border-top:1px dashed var(--line);
    padding-top:18px;
  }

  .findings .field-label{ margin-bottom:12px; }

  .finding{
    display:flex;
    gap:10px;
    font-size:13.5px;
    line-height:1.5;
    margin-bottom:8px;
    color:var(--ink);
  }

  .finding .mark{
    flex-shrink:0;
    font-weight:700;
    width:16px;
  }
  .finding.critical .mark{ color:var(--danger); }
  .finding.warn .mark{ color:var(--warning); }
  .finding.good .mark{ color:var(--success); }

  .actions{
    display:flex;
    gap:10px;
    margin-top:24px;
  }

  .btn{
    font-family: system-ui, sans-serif;
    font-size:13px;
    font-weight:600;
    padding:11px 18px;
    border-radius:4px;
    border:1px solid var(--line);
    background:var(--surface);
    color:var(--ink);
    cursor:pointer;
    letter-spacing:0.01em;
  }
  .btn:hover{ background:var(--paper); }
  .btn.primary{
    background:var(--vault);
    border-color:var(--vault);
    color:#fff;
  }
  .btn.primary:hover{ background:#4A7AA8; }

  .footnote{
    margin-top:20px;
    font-size:11px;
    color:var(--ink-soft);
    display:flex;
    align-items:center;
    gap:6px;
    font-family: ui-monospace, monospace;
  }

  @media (max-width:480px){
    .letterhead{ flex-direction:column; gap:10px; }
    .doc-id{ text-align:left; }
    .data-table{ grid-template-columns:1fr; }
  }
</style>
</head>
<body>

<div class="sheet">
  <div class="letterhead">
    <div>
      <h1>Password Security Assessment</h1>
      <div class="sub">DecodeLabs &mdash; Project 1 Extended</div>
    </div>
    <div class="doc-id" id="docId"></div>
  </div>

  <div class="body">
    <div class="field-label">Subject Password</div>
    <div class="input-row">
      <input id="pwInput" type="password" placeholder="type a password to assess&hellip;" autocomplete="off" spellcheck="false">
      <button class="eye-btn" id="eyeBtn">SHOW</button>
    </div>

    <div class="verdict-wrap">
      <div class="meter">
        <div class="meter-track"><div class="meter-fill" id="meterFill"></div></div>
        <div class="meter-scale"><span>Weak</span><span>Medium</span><span>Strong</span></div>
      </div>
      <div class="stamp" id="stamp">No Input</div>
    </div>

    <div class="data-table">
      <div class="data-cell">
        <div class="k">Length</div>
        <div class="v" id="valLength">&mdash;</div>
      </div>
      <div class="data-cell">
        <div class="k">Entropy</div>
        <div class="v" id="valEntropy">&mdash;</div>
      </div>
      <div class="data-cell">
        <div class="k">Known Weak List</div>
        <div class="v" id="valBreach">&mdash;</div>
      </div>
      <div class="data-cell">
        <div class="k">Est. Crack Time</div>
        <div class="v" id="valCrack">&mdash;</div>
      </div>
    </div>

    <div class="chips">
      <div class="chip" id="chipUpper">Uppercase</div>
      <div class="chip" id="chipLower">Lowercase</div>
      <div class="chip" id="chipDigit">Digits</div>
      <div class="chip" id="chipSymbol">Symbols</div>
    </div>

    <div class="findings">
      <div class="field-label">Findings &amp; Recommendations</div>
      <div id="findingsList"></div>
    </div>

    <div class="actions">
      <button class="btn primary" id="genBtn">Generate Strong Password</button>
      <button class="btn" id="copyBtn">Copy</button>
      <button class="btn" id="clearBtn">Clear</button>
    </div>

    <div class="footnote">
      <span>&#128274;</span>
      <span>Assessed locally in your browser. Nothing is sent anywhere.</span>
    </div>
  </div>
</div>

<script>
  const COMMON_PASSWORDS = new Set([
    "123456","123456789","qwerty","password","12345678","111111","123123",
    "abc123","password1","iloveyou","admin","letmein","welcome","monkey",
    "dragon","qwerty123","1q2w3e4r","000000","1234","12345","passw0rd",
    "football","baseball","master","superman","trustno1","asdf1234"
  ]);

  const pwInput = document.getElementById('pwInput');
  const eyeBtn = document.getElementById('eyeBtn');
  const meterFill = document.getElementById('meterFill');
  const stamp = document.getElementById('stamp');
  const valLength = document.getElementById('valLength');
  const valEntropy = document.getElementById('valEntropy');
  const valBreach = document.getElementById('valBreach');
  const valCrack = document.getElementById('valCrack');
  const findingsList = document.getElementById('findingsList');
  const chips = {
    upper: document.getElementById('chipUpper'),
    lower: document.getElementById('chipLower'),
    digit: document.getElementById('chipDigit'),
    symbol: document.getElementById('chipSymbol')
  };

  document.getElementById('docId').textContent =
    'REF: PSA-' + Math.random().toString(36).slice(2,8).toUpperCase() +
    '\n' + new Date().toLocaleDateString();

  eyeBtn.addEventListener('click', () => {
    const showing = pwInput.type === 'text';
    pwInput.type = showing ? 'password' : 'text';
    eyeBtn.textContent = showing ? 'SHOW' : 'HIDE';
  });

  function poolSize(pw){
    let pool = 0;
    if(/[a-z]/.test(pw)) pool += 26;
    if(/[A-Z]/.test(pw)) pool += 26;
    if(/[0-9]/.test(pw)) pool += 10;
    if(/[^a-zA-Z0-9]/.test(pw)) pool += 32;
    return pool || 1;
  }

  function calcEntropy(pw){
    const pool = poolSize(pw);
    return pw.length * Math.log2(pool);
  }

  function crackTimeLabel(entropyBits){
    // assume 10 billion guesses/sec (fast offline attack, e.g. GPU hash cracking)
    const guessesPerSecond = 1e10;
    const combinations = Math.pow(2, entropyBits);
    const seconds = combinations / (2 * guessesPerSecond); // average case

    if(seconds < 1) return "Instant";
    const units = [
      ["years", 60*60*24*365],
      ["days", 60*60*24],
      ["hours", 60*60],
      ["minutes", 60],
      ["seconds", 1]
    ];
    for(const [label, secInUnit] of units){
      const val = seconds / secInUnit;
      if(val >= 1){
        if(label === "years" && val > 1e6) return "Millions of years";
        if(label === "years" && val > 1000) return Math.round(val).toLocaleString() + " years";
        return Math.round(val) + " " + label;
      }
    }
    return "Instant";
  }

  function hasSequential(pw){
    const seqs = ["0123456789","abcdefghijklmnopqrstuvwxyz","qwertyuiop","asdfghjkl","zxcvbnm"];
    const low = pw.toLowerCase();
    for(const seq of seqs){
      for(let i=0;i<=seq.length-3;i++){
        if(low.includes(seq.slice(i,i+3))) return true;
      }
    }
    return false;
  }

  function hasRepeats(pw){
    return /(.)\1\1/.test(pw); // 3+ repeated chars in a row
  }

  function assess(pw){
    if(!pw){
      meterFill.style.width = '0%';
      meterFill.style.background = 'var(--line)';
      stamp.textContent = 'No Input';
      stamp.className = 'stamp';
      valLength.textContent = '\u2014';
      valEntropy.textContent = '\u2014';
      valBreach.textContent = '\u2014';
      valBreach.className = 'v';
      valCrack.textContent = '\u2014';
      Object.values(chips).forEach(c => c.className = 'chip');
      findingsList.innerHTML = '';
      return;
    }

    const isCommon = COMMON_PASSWORDS.has(pw.toLowerCase());
    const entropy = calcEntropy(pw);
    const types = {
      upper: /[A-Z]/.test(pw),
      lower: /[a-z]/.test(pw),
      digit: /[0-9]/.test(pw),
      symbol: /[^a-zA-Z0-9]/.test(pw)
    };
    const typeCount = Object.values(types).filter(Boolean).length;

    chips.upper.className = 'chip' + (types.upper ? ' on' : '');
    chips.lower.className = 'chip' + (types.lower ? ' on' : '');
    chips.digit.className = 'chip' + (types.digit ? ' on' : '');
    chips.symbol.className = 'chip' + (types.symbol ? ' on' : '');

    valLength.textContent = pw.length + ' chars';
    valEntropy.textContent = entropy.toFixed(1) + ' bits';

    let score; // 0-100
    let label;

    if(isCommon){
      score = 0;
      label = 'weak';
      valBreach.textContent = 'FLAGGED';
      valBreach.className = 'v danger';
      valCrack.textContent = 'Instant';
    } else {
      score = Math.min(100, Math.round((entropy / 80) * 100));
      if(typeCount < 2 || score < 30) label = 'weak';
      else if(typeCount >= 3 && score >= 65) label = 'strong';
      else label = 'medium';

      valBreach.textContent = 'Clean';
      valBreach.className = 'v success';
      valCrack.textContent = crackTimeLabel(entropy);
    }

    meterFill.style.width = score + '%';
    const colorMap = { weak: 'var(--danger)', medium: 'var(--warning)', strong: 'var(--success)' };
    meterFill.style.background = colorMap[label];

    const labelText = { weak: 'Weak', medium: 'Medium', strong: 'Strong' };
    stamp.textContent = isCommon ? 'Classified: Weak' : labelText[label];
    stamp.className = 'stamp ' + label;

    // Findings
    const findings = [];
    if(isCommon){
      findings.push(['critical','This exact password appears on a known common/leaked password list.']);
      findings.push(['critical','Change it immediately and never reuse it anywhere.']);
    } else {
      if(pw.length < 12) findings.push(['warn', 'Use at least 12 characters for stronger entropy.']);
      if(!types.upper) findings.push(['warn', 'Add an uppercase letter (A\u2013Z).']);
      if(!types.lower) findings.push(['warn', 'Add a lowercase letter (a\u2013z).']);
      if(!types.digit) findings.push(['warn', 'Add a digit (0\u20139).']);
      if(!types.symbol) findings.push(['warn', 'Add a symbol (e.g. ! @ # $ %).']);
      if(hasSequential(pw)) findings.push(['warn', "Avoid sequential patterns like '123' or 'qwerty'."]);
      if(hasRepeats(pw)) findings.push(['warn', 'Avoid repeating the same character three or more times in a row.']);
      if(findings.length === 0) findings.push(['good', 'Strong entropy and good character variety. Keep it safe and don\u2019t reuse it elsewhere.']);
    }

    findingsList.innerHTML = findings.map(([type,text]) => {
      const mark = type === 'critical' ? '\u25CF' : (type === 'warn' ? '\u25B2' : '\u2713');
      return `<div class="finding ${type}"><span class="mark">${mark}</span><span>${text}</span></div>`;
    }).join('');
  }

  pwInput.addEventListener('input', () => assess(pwInput.value));

  document.getElementById('clearBtn').addEventListener('click', () => {
    pwInput.value = '';
    assess('');
    pwInput.focus();
  });

  document.getElementById('copyBtn').addEventListener('click', () => {
    if(!pwInput.value) return;
    navigator.clipboard.writeText(pwInput.value).then(() => {
      const btn = document.getElementById('copyBtn');
      const orig = btn.textContent;
      btn.textContent = 'Copied';
      setTimeout(() => btn.textContent = orig, 1200);
    });
  });

  document.getElementById('genBtn').addEventListener('click', () => {
    const lower = 'abcdefghijklmnopqrstuvwxyz';
    const upper = lower.toUpperCase();
    const digits = '0123456789';
    const symbols = '!@#$%^&*()-_=+?';
    const all = lower + upper + digits + symbols;

    let pw = '';
    // guarantee at least one of each type
    pw += lower[Math.floor(Math.random()*lower.length)];
    pw += upper[Math.floor(Math.random()*upper.length)];
    pw += digits[Math.floor(Math.random()*digits.length)];
    pw += symbols[Math.floor(Math.random()*symbols.length)];
    for(let i=0;i<12;i++){
      pw += all[Math.floor(Math.random()*all.length)];
    }
    // shuffle
    pw = pw.split('').sort(() => Math.random()-0.5).join('');

    pwInput.type = 'text';
    eyeBtn.textContent = 'HIDE';
    pwInput.value = pw;
    assess(pw);
  });

  assess('');
</script>
</body>
</html>
